# ── LLM Provider ────────────────────────────────────────────────────────────
# MODEL_PROVIDER: mock | ollama | openai_compatible | azure_openai
MODEL_PROVIDER=mock
MODEL_NAME=llama3.1
MODEL_ENDPOINT=http://localhost:11434
MODEL_API_KEY=

# Enable LLM reasoning on all specialist agents (requires a real provider above)
USE_LLM=false

# ── Orchestration backend (switchable) ───────────────────────────────────────
# ORCHESTRATION_BACKEND: native_dag | autogen | ms_agent_framework
# If unset: USE_MS_AGENT_FRAMEWORK > USE_AUTOGEN > native_dag
ORCHESTRATION_BACKEND=native_dag

# Microsoft Agent Framework (~50% placeholder — runs native DAG until SDK wired)
USE_MS_AGENT_FRAMEWORK=false

# Microsoft AutoGen multi-agent group-chat orchestration
USE_AUTOGEN=false

# ── Azure AI Foundry (placeholder — model routing for agents) ─────────────────
USE_AZURE_AI_FOUNDRY=false
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_DEPLOYMENT_ORCH=gpt-4o
AZURE_AI_FOUNDRY_DEPLOYMENT_SPECIALIST=gpt-4o-mini

# ── Azure AI Search (placeholder — RAG over KB index) ─────────────────────────
USE_AZURE_AI_SEARCH=false
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_KB=eve-cater-kb

# ── Ollama (local) ───────────────────────────────────────────────────────────
# MODEL_PROVIDER=ollama
# MODEL_NAME=llama3.1             # or mistral, gemma, phi3, etc.
# MODEL_ENDPOINT=http://localhost:11434

# ── OpenAI-compatible (GPT, Groq, Together, LM Studio) ──────────────────────
# MODEL_PROVIDER=openai_compatible
# MODEL_NAME=gpt-4o-mini
# MODEL_ENDPOINT=https://api.openai.com/v1
# MODEL_API_KEY=sk-...

# ── Inventory / scheduling simulation ───────────────────────────────────────
SIMULATE_INVENTORY=false
SIMULATE_VENDOR_DELAY=false

# ── Azure OpenAI (optional alternative to ollama/openai_compatible) ──────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_ORCH=gpt-4o
AZURE_OPENAI_DEPLOYMENT_SPECIALIST=gpt-4o-mini

# ── Shared context ────────────────────────────────────────────────────────────
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
# Structured JSON logs (stdout) for App Insights ingestion pipelines
STRUCTURED_LOG_JSON=1

# OpenTelemetry FastAPI (optional): pip install opentelemetry-api opentelemetry-sdk opentelemetry-instrumentation-fastapi
ENABLE_OTEL=0

# Entra ID JWT (optional): set ENTRA_AUDIENCE to require Bearer tokens
ENTRA_AUDIENCE=
ENTRA_TENANT_ID=
